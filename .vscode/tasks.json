{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev server",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": {
				"owner": "vite",
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*VITE.*",
					"endsPattern": ".*(Local|ready in).*"
				}
			}
		}
	]
}
